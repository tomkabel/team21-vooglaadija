# ===========================================
# Docker Compose variables
# Used by docker-compose.yml to configure Postgres
# and construct DATABASE_URL for containerized services
# ===========================================

# Podman compatibility: use Docker format for healthcheck support
# Required because Podman defaults to OCI format which doesn't support HEALTHCHECK
# Only needed when using podman-compose instead of docker-compose
# COMPOSE_FORMAT=docker

DB_USER=postgres
DB_PASSWORD=              # REQUIRED - set a strong password
DB_NAME=ytprocessor
REDIS_PASSWORD=           # REQUIRED - set a strong password for Redis auth

# ===========================================
# Application variables
# Read by app.config.Settings (pydantic-settings)
#
# For local non-Docker dev, also set:
#   DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@localhost:5432/ytprocessor
# ===========================================

# JWT secret - MUST be at least 32 characters
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Redis connection (URL without password for local dev without auth)
REDIS_URL=redis://localhost:6379

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File expiry (hours)
FILE_EXPIRE_HOURS=24

# Storage path for downloaded files
STORAGE_PATH=./storage

# Cookie security — set to True in production (requires HTTPS)
# Leave False for local development without TLS
COOKIE_SECURE=False

# ===========================================
# NetData Configuration
# Get claim token from: app.netdata.cloud -> Nodes -> Claim nodes
# ===========================================

# Claim token from NetData Cloud (optional for Docker, required for claiming)
NETDATA_CLAIM_TOKEN=

# Claim URL (usually https://app.netdata.cloud)
NETDATA_CLAIM_URL=https://app.netdata.cloud

# Room ID for organizing nodes in NetData Cloud (optional)
NETDATA_CLAIM_ROOM=

# ===========================================
# Sentry Error Tracking (Optional)
# Get DSN from: sentry.io -> Project -> Settings -> Client Keys
# ===========================================

SENTRY_DSN=

# ===========================================
# Cloudflare DNS Challenge (Optional)
# Required only if using deploy.sh with DNS-01 ACME challenge.
# Get Global API Key from: https://dash.cloudflare.com/profile/api-tokens
# ===========================================

# CLOUDFLARE_EMAIL=
# CLOUDFLARE_API_KEY=

# ===========================================
# Observability Settings
# ===========================================

# Enable/disable features (set to false to reduce overhead)
FEATURE_METRICS_ENABLED=true
FEATURE_TRACING_ENABLED=false

# OpenTelemetry Configuration (if FEATURE_TRACING_ENABLED=true)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=vooglaadija
