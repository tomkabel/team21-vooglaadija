# ===========================================
# Docker Compose variables
# Used by docker-compose.yml to configure Postgres
# and construct DATABASE_URL for containerized services
# ===========================================
DB_USER=postgres
DB_PASSWORD=              # REQUIRED - set a strong password
DB_NAME=ytprocessor

# ===========================================
# Application variables
# Read by app.config.Settings (pydantic-settings)
#
# For local non-Docker dev, also set:
#   DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@localhost:5432/ytprocessor
# ===========================================

# JWT secret - MUST be at least 32 characters
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Redis connection
REDIS_URL=redis://localhost:6379

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File expiry (hours)
FILE_EXPIRE_HOURS=24

# Storage path for downloaded files
STORAGE_PATH=./storage
